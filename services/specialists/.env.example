# Quantitative specialists (LangGraph) — service config
PORT=8000

# AI/ML API (OpenAI-compatible) — same key the TS committee uses
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_API_KEY=

# Model per specialist (each falls back to gpt-4o-mini if unset)
MODEL_ENVIRONMENTAL=gpt-4o-mini
MODEL_CAPEX=gpt-4o-mini
MODEL_INSURANCE=gpt-4o-mini

# Band base URL (shared)
BAND_BASE_URL=https://app.band.ai/api/v1

# Each specialist posts to Band under its OWN identity (its own API key).
# All three are required — there is no shared/fallback identity.
BAND_ENVIRONMENTAL_API_KEY=
BAND_CAPEX_API_KEY=
BAND_INSURANCE_API_KEY=

# Used only by the Environmental agent for any incidental calls; the TS app owns
# the agent IDs (it adds participants and @mentions them).
BAND_ENVIRONMENTAL_AGENT_ID=
