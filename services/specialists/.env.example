# Environmental specialist (LangGraph) — service config
PORT=8000

# AI/ML API (OpenAI-compatible) — same key the TS committee uses
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_API_KEY=
MODEL_ENVIRONMENTAL=gpt-4o-mini

# Band identity for the Environmental agent (its own first-class participant)
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_ENVIRONMENTAL_API_KEY=
BAND_ENVIRONMENTAL_AGENT_ID=

# Optional: give CapEx / Insurance their OWN Band identities (real distinct agents
# with their own handles). The Python service posts as them using these keys; if
# unset, they post under the Environmental identity above.
BAND_CAPEX_API_KEY=
BAND_INSURANCE_API_KEY=
