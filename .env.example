# ============================================================
# DueDiligenceOS (Next.js app) — environment template.
# Copy to .env.local and never commit it. The Python specialists service has its
# own env file: services/specialists/.env.example.
# ============================================================

# ---- Required ----

# Neon Postgres connection string (https://neon.tech)
DATABASE_URL=

# AI/ML API key — one key, many models (https://aimlapi.com)
AIML_API_KEY=

# URL of the Python specialists service (services/specialists).
# Local: http://127.0.0.1:8000   Deployed: the service's public URL.
SPECIALISTS_URL=http://127.0.0.1:8000

# Band agents — register at https://app.band.ai (New Agent -> External Agent).
# Core agents post as themselves, so each needs an Agent ID AND an API key.
# Specialists are only added and @mentioned by the app, so they need an Agent ID
# only. Their API keys live in services/specialists/.env, not here.
BAND_ARCHIVIST_AGENT_ID=
BAND_ARCHIVIST_API_KEY=
BAND_REGULATORY_AGENT_ID=
BAND_REGULATORY_API_KEY=
BAND_LEGAL_AGENT_ID=
BAND_LEGAL_API_KEY=
BAND_FINANCIAL_AGENT_ID=
BAND_FINANCIAL_API_KEY=
BAND_SYNTHESIS_AGENT_ID=
BAND_SYNTHESIS_API_KEY=
BAND_ENVIRONMENTAL_AGENT_ID=
BAND_CAPEX_AGENT_ID=
BAND_INSURANCE_AGENT_ID=

# ---- Optional ----

# Lock all write endpoints behind a bearer token (recommended for a public URL).
# APP_API_TOKEN=

# Per-agent model overrides. Sensible defaults are set in code, so leave these
# unset unless your AI/ML catalog needs different IDs.
# MODEL_ARCHIVIST=
# MODEL_REGULATORY=
# MODEL_LEGAL=
# MODEL_FINANCIAL=
# MODEL_SYNTHESIS=

# Base URLs (defaults shown — only set to override).
# AIML_BASE_URL=https://api.aimlapi.com/v1
# BAND_BASE_URL=https://app.band.ai/api/v1
