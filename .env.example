# ============================================================
# DueDiligenceOS — environment template. Copy to .env.local (never commit it).
# ============================================================

# ---- Database (Neon Postgres) ----
# Create a database at https://neon.tech and paste the connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Band agents ----
# Register 8 agents at https://app.band.ai (Agents -> New Agent -> External Agent):
# 5 reasoning agents + 3 quantitative specialists. For each, collect the Agent
# UUID, API Key, and Handle. The specialists are recruited into the room on demand.
BAND_BASE_URL=https://app.band.ai/api/v1

# -- Reasoning agents (TypeScript) --
BAND_ARCHIVIST_AGENT_ID=
BAND_ARCHIVIST_API_KEY=
BAND_ARCHIVIST_HANDLE=

BAND_REGULATORY_AGENT_ID=
BAND_REGULATORY_API_KEY=
BAND_REGULATORY_HANDLE=

BAND_LEGAL_AGENT_ID=
BAND_LEGAL_API_KEY=
BAND_LEGAL_HANDLE=

BAND_FINANCIAL_AGENT_ID=
BAND_FINANCIAL_API_KEY=
BAND_FINANCIAL_HANDLE=

BAND_SYNTHESIS_AGENT_ID=
BAND_SYNTHESIS_API_KEY=
BAND_SYNTHESIS_HANDLE=

# -- Quantitative specialists (Python / LangGraph) — recruited on demand --
# Each specialist with its own ID joins the room as a distinct Band participant;
# if a specialist's ID is left blank, recruiting it is skipped gracefully.
BAND_ENVIRONMENTAL_AGENT_ID=
BAND_ENVIRONMENTAL_API_KEY=
BAND_ENVIRONMENTAL_HANDLE=

BAND_CAPEX_AGENT_ID=
BAND_CAPEX_API_KEY=
BAND_CAPEX_HANDLE=

BAND_INSURANCE_AGENT_ID=
BAND_INSURANCE_API_KEY=
BAND_INSURANCE_HANDLE=

# ---- Python specialist service (FastAPI + LangGraph) ----
# Base URL of the local/hosted specialist service (services/specialists).
SPECIALISTS_URL=http://127.0.0.1:8000

# ---- LLM provider (AI/ML API — OpenAI-compatible gateway) ----
# One key, many models. Get it at https://aimlapi.com
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_API_KEY=

# Per-agent model IDs — must match the AI/ML API catalog exactly.
# Google models are namespaced (google/...); Anthropic (anthropic/...); OpenAI are plain.
MODEL_ARCHIVIST=google/gemini-2.5-flash
MODEL_REGULATORY=anthropic/claude-sonnet-4-6-20260218
MODEL_LEGAL=anthropic/claude-sonnet-4-6-20260218
MODEL_FINANCIAL=gpt-4o
MODEL_SYNTHESIS=gpt-4o-mini
MODEL_ENVIRONMENTAL=gpt-4o-mini
MODEL_CAPEX=gpt-4o-mini
MODEL_INSURANCE=gpt-4o-mini

# ---- Security (optional) ----
# Set to lock all write endpoints (create/decide/chat/simulate/extract/delete)
# behind a bearer token. Leave unset for an open demo. When set, send the token
# as `Authorization: Bearer <token>` or `X-API-Token: <token>`.
# APP_API_TOKEN=
