# ============================================================
# DueDiligenceOS — environment template. Copy to .env.local (never commit it).
# More keys are added as features land (providers, Redis).
# ============================================================

# ---- Database (Neon Postgres) ----
# Create a database at https://neon.tech and paste the connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---- Band agents ----
# Register 5 agents at https://app.band.ai (Agents → New Agent → External Agent).
# For each, collect the Agent UUID, API Key, and Handle.
BAND_BASE_URL=https://app.band.ai/api/v1

BAND_MARKET_AGENT_ID=
BAND_MARKET_API_KEY=
BAND_MARKET_HANDLE=

BAND_DD_AGENT_ID=
BAND_DD_API_KEY=
BAND_DD_HANDLE=

BAND_RISK_AGENT_ID=
BAND_RISK_API_KEY=
BAND_RISK_HANDLE=

BAND_LEGAL_AGENT_ID=
BAND_LEGAL_API_KEY=
BAND_LEGAL_HANDLE=

BAND_FINANCE_AGENT_ID=
BAND_FINANCE_API_KEY=
BAND_FINANCE_HANDLE=
